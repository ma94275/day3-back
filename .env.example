# ── .env 만들기 ──────────────────────────────────────
# 1) 이 파일을 복사해서 이름을 .env 로 바꾼다 (example 떼기)
#    ⚠️ "이름 변경"이 아니라 "복사" — 이 example 파일은 저장소에 남겨둬야 한다
# 2) 아래 값을 우리 팀 Supabase 접속 문자열로 교체한다
#
# ⚠️ 접속 문자열 찾는 법 (Day 2 복습):
#   Supabase → Connect → 반드시 "Session pooler" 탭!
#   맨 처음 보이는 Direct connection 문자열은 쓰지 마세요 (학교 네트워크에서 안 될 수 있음)
#   postgresql:// 로 시작하는 문자열이어야 한다 (https://...supabase.co 는 웹 API용, 여기선 안 됨)
#
# ⚠️ [YOUR-PASSWORD] 부분을 진짜 비밀번호로 바꾸는 것 잊지 말기
# ⚠️ .env는 절대 GitHub에 올리지 않는다 (.gitignore가 막아주지만, 원리를 알 것)

DATABASE_URL=

# ── 이메일 인증 로그인 설정 ──────────────────────────
# JWT 토큰 서명에 쓸 비밀 키. 아무 값이나 길고 무작위하게 넣으면 된다.
# (비워두면 개발용 기본값으로 동작하지만, 배포 시엔 꼭 채울 것)
JWT_SECRET=

# 인증 메일을 보낼 Gmail 계정과 "앱 비밀번호" (일반 로그인 비번 아님!)
#   1) Google 계정 → 보안 → 2단계 인증 켜기
#   2) "앱 비밀번호" 메뉴에서 16자리 비밀번호 생성 → GMAIL_APP_PASSWORD에 붙여넣기
# ⚠️ 둘 다 비워두면 실제 메일 대신 인증 코드가 서버 콘솔에 출력된다 (개발 모드).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# 학교/회사 네트워크가 SSL을 중간에서 가로채(보안 프록시)
# "unable to verify the first certificate" 에러가 날 때만 true 로 켠다.
# (인증서 검증을 끄는 임시 우회책 — 일반 네트워크/배포 환경에서는 비워둘 것)
SMTP_INSECURE_TLS=
